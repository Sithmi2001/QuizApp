<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Linear gradient: dark purple → medium purple → light purple -->
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#FAF1E6"
    android:centerColor="#D9C4B0"
    android:endColor="#F6F0F0"
    android:useLevel="false"/>

    <!-- Rounded corners for all pages -->
    <corners android:radius="24dp"/>

    <!-- Optional white stroke -->
    <stroke
        android:width="2dp"
        android:color="#FFFFFF"/>
</shape>
