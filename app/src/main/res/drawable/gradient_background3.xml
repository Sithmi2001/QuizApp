<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Linear gradient: soft sky blue → lavender → light pink -->
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#FAF3F0"
    android:centerColor="#EBD6FB"
    android:endColor="#C5BAFF"
    android:useLevel="false"/>

    <!-- Rounded corners for a modern feel -->
    <corners android:radius="24dp"/>

    <!-- Thin white stroke for separation -->
    <stroke
        android:width="2dp"
        android:color="#FFFFFF"/>
</shape>
