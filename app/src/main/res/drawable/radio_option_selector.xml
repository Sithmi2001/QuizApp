<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Checked / selected state -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="#5E2D79"/> <!-- same background -->
            <stroke
                android:width="3dp"
                android:color="#FFD700"/> <!-- border color when selected -->
            <corners android:radius="16dp"/>
            <padding
                android:left="16dp"
                android:top="16dp"
                android:right="16dp"
                android:bottom="16dp"/>
        </shape>
    </item>

    <!-- Default / unchecked state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#5E2D79"/> <!-- same background -->
            <stroke
                android:width="0dp"
                android:color="#00000000"/> <!-- no border -->
            <corners android:radius="16dp"/>
            <padding
                android:left="16dp"
                android:top="16dp"
                android:right="16dp"
                android:bottom="16dp"/>
        </shape>
    </item>

</selector>
