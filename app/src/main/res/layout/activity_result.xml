<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EADDFF"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:textAlignment="center"
        android:layout_marginTop="60dp"
        android:gravity="center">

        <!-- Header -->
        <TextView
            android:id="@+id/textResultHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quiz Results"
            android:paddingBottom="28dp"
            android:paddingTop="30dp"
            android:textSize="35sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="24dp"/>

        <!-- Correct Answers Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/card_background"
            android:elevation="4dp">

            <TextView
                android:id="@+id/textCorrect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Correct Answers"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Wrong Answers Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/card_background"
            android:elevation="4dp">

            <TextView
                android:id="@+id/textWrong"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Wrong Answers"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Percentage Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/card_background"
            android:elevation="4dp">

            <TextView
                android:id="@+id/textScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Percentage"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Time Taken Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/card_background"
            android:elevation="4dp"
            android:orientation="horizontal"
            android:padding="16dp"
            android:textAlignment="center">

            <TextView
                android:id="@+id/textTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Time Taken"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Buttons -->
        <Button
            android:id="@+id/buttonRestart"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/button_darkpurple_gradient"
            android:text="Restart Quiz"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

        <Button
            android:id="@+id/buttonExit"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:background="@drawable/button_darkpurple_gradient"
            android:text="Finish AND Exit"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

    </LinearLayout>
</ScrollView>
