<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/thankyou_gradient"
    android:padding="24dp">

    <!-- Rating Section -->
    <LinearLayout
        android:id="@+id/ratingLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/thankyou_card"
        android:elevation="8dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How satisfied are you with this app?"
            android:textSize="20sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="#0D1164"
            android:layout_marginBottom="16dp"/>

        <SeekBar
            android:id="@+id/seekBarSatisfaction"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:max="10"
            android:backgroundTint="@color/black"
            android:progress="5"/>

        <TextView
            android:id="@+id/textRatingValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selected: 5 / 10"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:textColor="#333333"/>

        <Button
            android:id="@+id/buttonSubmit"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Submit"
            android:layout_marginTop="24dp"
            android:backgroundTint="#0D1164"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Thank You Card (Hidden at start) -->
    <LinearLayout
        android:id="@+id/thankYouLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:background="@drawable/thankyou_card"
        android:elevation="8dp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Big Emoji -->
        <TextView
            android:id="@+id/emojiCelebrate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="50sp"
            android:layout_marginBottom="16dp"/>

        <!-- Main Thank You -->
        <TextView
            android:id="@+id/textThankYouMain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thank You!"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#0D1164"
            android:shadowColor="#80000000"
            android:shadowDx="3"
            android:shadowDy="3"
            android:shadowRadius="6"
            android:fontFamily="sans-serif-condensed"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- Subtext -->
        <TextView
            android:id="@+id/textThankYouSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your feedback helps us improve!"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#000000"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:lineSpacingExtra="4dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
